{{- /*
   zsh integration for `aims bring` — generated by `aims init zsh`. This is TRUSTED code: it
   contains no agent data. Agent values arrive only at runtime, as the parsed contents of the
   `ctx` associative array (capture-as-data: parsed with `read -r`, never eval'd), so a hostile
   implant string can never execute here. P1: single agent, no context stack yet.
*/ -}}
# aims `bring` shell integration (zsh). Source once from your ~/.zshrc:
#     source <(aims init zsh)

# _aims_apply_prompt prepends the current agent segment to the operator's saved prompt. The name
# is sanitized server-side (no $, `, % or control bytes), so it is inert even under PROMPT_SUBST.
_aims_apply_prompt() {
    PROMPT="%F{red}[${AIMS_AGENT_NAME:-$AIMS_AGENT_ID}]%f ${_aims_saved_prompt}"
}

# bring makes the current shell "about" a c2 agent: it fetches the agent context from the server
# as inert key<TAB>value data, exports it, sets the prompt segment and the `aimsi` task-root
# alias. Run `leave` to restore the shell.
bring() {
    emulate -L zsh
    local id="$1"

    if [[ -z "$id" ]]; then
        if [[ -n "$AIMS_AGENT_ID" ]]; then
            print -r -- "[*] current agent: ${AIMS_AGENT_NAME:-$AIMS_AGENT_ID} (alias: aimsi)"
        else
            print -r -- "[*] no agent context — usage: bring <agent-id>"
        fi
        return 0
    fi

    local payload
    payload="$(command aims bring "$id")" || return 1

    # Parse key<TAB>value lines as pure data — no eval, so hostile agent strings cannot execute.
    local k v
    local -A ctx
    while IFS=$'\t' read -r k v; do
        [[ -n "$k" ]] && ctx[$k]="$v"
    done <<< "$payload"

    if [[ -z "${ctx[{{.ID}}]}" ]]; then
        print -r -- "[!] bring: empty agent context for '$id'" >&2
        return 1
    fi

    # On the first bring in this shell, remember the prompt so `leave` can restore it.
    if [[ -z "$AIMS_AGENT_ID" ]]; then
        _aims_saved_prompt="$PROMPT"
    fi

    export AIMS_AGENT_ID="${ctx[{{.ID}}]}"
    export AIMS_AGENT_NAME="${ctx[{{.Name}}]}"
    export AIMS_AGENT_TOOL="${ctx[{{.Tool}}]}"
    export AIMS_AGENT_CWD="${ctx[{{.CWD}}]}"

    # Agent-bound task root. Single-quoted so $AIMS_AGENT_ID is expanded at use time, not baked.
    alias aimsi='aims c2 task "$AIMS_AGENT_ID"'

    _aims_apply_prompt
    print -r -- "[+] brought ${AIMS_AGENT_NAME:-$AIMS_AGENT_ID} (alias: aimsi)"
}

# leave restores the shell to its pre-bring state.
leave() {
    emulate -L zsh
    if [[ -z "$AIMS_AGENT_ID" ]]; then
        print -r -- "[*] no agent context to leave"
        return 0
    fi
    PROMPT="$_aims_saved_prompt"
    unset _aims_saved_prompt
    unset AIMS_AGENT_ID AIMS_AGENT_NAME AIMS_AGENT_TOOL AIMS_AGENT_CWD
    unalias aimsi 2>/dev/null
    print -r -- "[-] left agent context"
}
