{{- /*
   zsh integration for `aims bring` — generated by `aims init zsh`. This is TRUSTED code: it
   contains no agent data. Agent values arrive only at runtime, as the parsed contents of the
   `ctx` associative array (capture-as-data: parsed with `read -r`, never eval'd), so a hostile
   implant string can never execute here. P2: nested contexts via a stack; `leave` pops.
*/ -}}
# aims `bring` shell integration (zsh). Source once from your ~/.zshrc:
#     source <(aims init zsh)

# _aims_apply_prompt rebuilds the prompt segment for the current agent: the name, plus a terse
# network-path summary when a route is known, the context stack depth when nested (>1) and the
# number of pending tasks when any. All values are sanitized server-side, so the segment is inert
# even under PROMPT_SUBST.
_aims_apply_prompt() {
    local seg="${AIMS_AGENT_NAME:-$AIMS_AGENT_ID}"
    if [[ -n "$AIMS_AGENT_ROUTE" ]]; then
        seg="$seg ⤳$AIMS_AGENT_ROUTE"
    fi
    if [[ -n "$AIMS_CONTEXT_DEPTH" ]] && (( AIMS_CONTEXT_DEPTH > 1 )); then
        seg="$seg ⇕$AIMS_CONTEXT_DEPTH"
    fi
    if (( ${AIMS_AGENT_PENDING:-0} > 0 )); then
        seg="$seg ⚑$AIMS_AGENT_PENDING"
    fi
    PROMPT="%F{red}[$seg]%f ${_aims_saved_prompt}"
}

# ─── server + running-scan indicator (right prompt) ─────────────────────────────────────────────
# Unlike the per-agent left segment above, these are live, server-GLOBAL figures: the server version
# and the count of connected operators, plus the number of running scans. They change independently
# of bring/leave — scans start and finish, operators come and go — so a bring-time snapshot would be
# stale at once. They are refreshed from a precmd hook (running before every prompt) rather than baked
# into $PROMPT, and fetched together by a single `aims prompt --terse` call — one teamserver connect
# per poll — throttled to at most once per AIMS_PROMPT_POLL_INTERVAL seconds and cached. That command
# emits three tab-separated fields (scans, version, connected); each is numeric or a dotted version,
# never agent-derived data, so all are inert under prompt expansion. The indicator renders in RPROMPT
# so it shows even with no agent brought, and composes with — rather than clobbers — the operator's
# own right prompt.
#
# Toggles (export before sourcing, or any time after — read live on each poll):
#   AIMS_SCAN_PROMPT=0            hide the running-scan segment
#   AIMS_SERVER_PROMPT=0          hide the server (version + operators) segment
#   AIMS_PROMPT_POLL_INTERVAL=5   minimum seconds between polls (default 5)
zmodload -F zsh/datetime b:EPOCHSECONDS 2>/dev/null

# Remember the operator's own right prompt once, so the indicator prefixes it instead of replacing
# it. The +set guard makes re-sourcing this file idempotent — it never captures our own segment.
if [[ -z "${_aims_saved_rprompt+set}" ]]; then
    typeset -g _aims_saved_rprompt="${RPROMPT-}"
fi

# _aims_prompt_poll refreshes the cached server/scan figures (throttled) and rebuilds RPROMPT.
# Registered as a precmd hook, it runs before each prompt; between polls it just re-renders the cache.
_aims_prompt_poll() {
    local scans_on=1 server_on=1
    [[ "${AIMS_SCAN_PROMPT:-1}" == (0|false|no) ]] && scans_on=0
    [[ "${AIMS_SERVER_PROMPT:-1}" == (0|false|no) ]] && server_on=0

    # Both segments off: restore the operator's own right prompt and don't poll (spend no connect).
    if (( ! scans_on && ! server_on )); then
        RPROMPT="$_aims_saved_rprompt"
        return
    fi

    local now="${EPOCHSECONDS:-0}" interval="${AIMS_PROMPT_POLL_INTERVAL:-5}"
    if [[ -z "${_aims_prompt_last_poll+set}" ]] || (( now - _aims_prompt_last_poll >= interval )); then
        typeset -g _aims_prompt_last_poll="$now"
        # Synchronous but throttled (poll-and-cache): one connect fetches every field. On failure
        # (server unreachable, aims not on PATH) keep the last known values rather than flap the prompt;
        # _aims_prompt_last_poll is still advanced, so a down server is retried at the interval, not
        # every keystroke. Fields: scans<TAB>version<TAB>connected — an empty (or malformed) field
        # means "no update", so a partial result never clears a good cached value.
        local line
        if line="$(command aims prompt --terse 2>/dev/null)"; then
            # Split the three columns by hand. `read`/`${(s::)}` treat tab as IFS-*whitespace* and would
            # collapse an empty leading field — mis-aligning the columns whenever one value is absent (an
            # empty field is how the command signals "no update"). `%%`/`#`/`##` keep empties in place.
            local scans="${line%%$'\t'*}" rest="${line#*$'\t'}"
            local ver="${rest%%$'\t'*}" conn="${rest##*$'\t'}"
            [[ "$scans" == <-> ]] && typeset -g _aims_scan_count="$scans"
            [[ "$ver" == <->.<->.<-> ]] && typeset -g _aims_server_version="$ver"
            [[ "$conn" == <-> ]] && typeset -g _aims_server_conn="$conn"
        fi
    fi

    local seg=""
    if (( server_on )) && [[ -n "${_aims_server_version-}" ]]; then
        # Server identity, always shown while connected: "aims v0.4.0", plus the connected-operator
        # count, labelled so a bare number never floats unexplained: "·2 ops" (singular "·1 op").
        seg="%F{green}aims v${_aims_server_version}%f"
        if [[ -n "${_aims_server_conn-}" ]]; then
            local onoun=ops
            (( _aims_server_conn == 1 )) && onoun=op
            seg="${seg} %F{green}·${_aims_server_conn} ${onoun}%f"
        fi
        seg="${seg} "
    fi
    if (( scans_on )) && (( ${_aims_scan_count:-0} > 0 )); then
        # Label the count so the glyph alone is never left to carry the meaning: "⟳2 scans".
        local noun=scans
        (( _aims_scan_count == 1 )) && noun=scan
        seg="${seg}%F{cyan}⟳${_aims_scan_count} ${noun}%f "
    fi
    RPROMPT="${seg}${_aims_saved_rprompt}"
}

autoload -Uz add-zsh-hook
add-zsh-hook precmd _aims_prompt_poll

# _aims_push saves the current agent context onto the stack (parallel arrays), so a nested `bring`
# can be undone by `leave`.
_aims_push() {
    _aims_stack_id+=("$AIMS_AGENT_ID")
    _aims_stack_name+=("$AIMS_AGENT_NAME")
    _aims_stack_tool+=("$AIMS_AGENT_TOOL")
    _aims_stack_cwd+=("$AIMS_AGENT_CWD")
    _aims_stack_route+=("$AIMS_AGENT_ROUTE")
    _aims_stack_pending+=("$AIMS_AGENT_PENDING")
}

# _aims_pop restores the top of the stack into the current agent env vars, then drops it.
_aims_pop() {
    export AIMS_AGENT_ID="${_aims_stack_id[-1]}"
    export AIMS_AGENT_NAME="${_aims_stack_name[-1]}"
    export AIMS_AGENT_TOOL="${_aims_stack_tool[-1]}"
    export AIMS_AGENT_CWD="${_aims_stack_cwd[-1]}"
    export AIMS_AGENT_ROUTE="${_aims_stack_route[-1]}"
    export AIMS_AGENT_PENDING="${_aims_stack_pending[-1]}"
    _aims_stack_id=("${(@)_aims_stack_id[1,-2]}")
    _aims_stack_name=("${(@)_aims_stack_name[1,-2]}")
    _aims_stack_tool=("${(@)_aims_stack_tool[1,-2]}")
    _aims_stack_cwd=("${(@)_aims_stack_cwd[1,-2]}")
    _aims_stack_route=("${(@)_aims_stack_route[1,-2]}")
    _aims_stack_pending=("${(@)_aims_stack_pending[1,-2]}")
}

# bring makes the current shell "about" a c2 agent: it fetches the agent context from the server as
# inert key<TAB>value data, exports it, updates the prompt and binds the `aimsi` task root. Nesting
# a second bring stacks the current context; `leave` pops back to it.
bring() {
    emulate -L zsh
    local id="$1"

    if [[ -z "$id" ]]; then
        if [[ -n "$AIMS_AGENT_ID" ]]; then
            print -r -- "[*] current agent: ${AIMS_AGENT_NAME:-$AIMS_AGENT_ID} (depth ${AIMS_CONTEXT_DEPTH:-1}, alias: aimsi)"
        else
            print -r -- "[*] no agent context — usage: bring <agent-id>"
        fi
        return 0
    fi

    local payload
    payload="$(command aims bring "$id")" || return 1

    # Parse key<TAB>value lines as pure data — no eval, so hostile agent strings cannot execute.
    local k v
    local -A ctx
    while IFS=$'\t' read -r k v; do
        [[ -n "$k" ]] && ctx[$k]="$v"
    done <<< "$payload"

    if [[ -z "${ctx[{{.ID}}]}" ]]; then
        print -r -- "[!] bring: empty agent context for '$id'" >&2
        return 1
    fi

    # First bring in this shell: remember the base prompt. Otherwise stack the current context.
    if [[ -n "$AIMS_AGENT_ID" ]]; then
        _aims_push
    else
        _aims_saved_prompt="$PROMPT"
    fi

    export AIMS_AGENT_ID="${ctx[{{.ID}}]}"
    export AIMS_AGENT_NAME="${ctx[{{.Name}}]}"
    export AIMS_AGENT_TOOL="${ctx[{{.Tool}}]}"
    export AIMS_AGENT_CWD="${ctx[{{.CWD}}]}"
    export AIMS_AGENT_ROUTE="${ctx[{{.Route}}]}"
    export AIMS_AGENT_PENDING="${ctx[{{.Pending}}]}"
    export AIMS_CONTEXT_DEPTH=$(( ${#_aims_stack_id[@]} + 1 ))

    # Agent-bound task root: a function (not an alias) so it forwards arguments and can carry
    # completion later. It reads the live $AIMS_AGENT_ID, so it always targets the current agent.
    aimsi() { command aims c2 task "$AIMS_AGENT_ID" "$@" }

    _aims_apply_prompt
    print -r -- "[+] brought ${AIMS_AGENT_NAME:-$AIMS_AGENT_ID} (depth $AIMS_CONTEXT_DEPTH, alias: aimsi)"
}

# leave pops one context; at the bottom of the stack it fully restores the pre-bring shell.
leave() {
    emulate -L zsh
    if [[ -z "$AIMS_AGENT_ID" ]]; then
        print -r -- "[*] no agent context to leave"
        return 0
    fi

    if (( ${#_aims_stack_id[@]} > 0 )); then
        _aims_pop
        export AIMS_CONTEXT_DEPTH=$(( ${#_aims_stack_id[@]} + 1 ))
        _aims_apply_prompt
        print -r -- "[-] returned to ${AIMS_AGENT_NAME:-$AIMS_AGENT_ID} (depth $AIMS_CONTEXT_DEPTH)"
        return 0
    fi

    PROMPT="$_aims_saved_prompt"
    unset _aims_saved_prompt
    unset AIMS_AGENT_ID AIMS_AGENT_NAME AIMS_AGENT_TOOL AIMS_AGENT_CWD AIMS_AGENT_ROUTE AIMS_AGENT_PENDING AIMS_CONTEXT_DEPTH
    unset _aims_stack_id _aims_stack_name _aims_stack_tool _aims_stack_cwd _aims_stack_route _aims_stack_pending
    unfunction aimsi 2>/dev/null
    print -r -- "[-] left agent context"
}
