{{- /*
   zsh integration for `aims bring` — generated by `aims init zsh`. This is TRUSTED code: it
   contains no agent data. Agent values arrive only at runtime, as the parsed contents of the
   `ctx` associative array (capture-as-data: parsed with `read -r`, never eval'd), so a hostile
   implant string can never execute here. P2: nested contexts via a stack; `leave` pops.
*/ -}}
# aims `bring` shell integration (zsh). Source once from your ~/.zshrc:
#     source <(aims init zsh)

# _aims_apply_prompt rebuilds the prompt segment for the current agent: the name, plus the context
# stack depth when nested (>1) and the number of pending tasks when any. All values are sanitized
# server-side, so the segment is inert even under PROMPT_SUBST.
_aims_apply_prompt() {
    local seg="${AIMS_AGENT_NAME:-$AIMS_AGENT_ID}"
    if [[ -n "$AIMS_CONTEXT_DEPTH" ]] && (( AIMS_CONTEXT_DEPTH > 1 )); then
        seg="$seg ⇕$AIMS_CONTEXT_DEPTH"
    fi
    if (( ${AIMS_AGENT_PENDING:-0} > 0 )); then
        seg="$seg ⚑$AIMS_AGENT_PENDING"
    fi
    PROMPT="%F{red}[$seg]%f ${_aims_saved_prompt}"
}

# _aims_push saves the current agent context onto the stack (parallel arrays), so a nested `bring`
# can be undone by `leave`.
_aims_push() {
    _aims_stack_id+=("$AIMS_AGENT_ID")
    _aims_stack_name+=("$AIMS_AGENT_NAME")
    _aims_stack_tool+=("$AIMS_AGENT_TOOL")
    _aims_stack_cwd+=("$AIMS_AGENT_CWD")
    _aims_stack_pending+=("$AIMS_AGENT_PENDING")
}

# _aims_pop restores the top of the stack into the current agent env vars, then drops it.
_aims_pop() {
    export AIMS_AGENT_ID="${_aims_stack_id[-1]}"
    export AIMS_AGENT_NAME="${_aims_stack_name[-1]}"
    export AIMS_AGENT_TOOL="${_aims_stack_tool[-1]}"
    export AIMS_AGENT_CWD="${_aims_stack_cwd[-1]}"
    export AIMS_AGENT_PENDING="${_aims_stack_pending[-1]}"
    _aims_stack_id=("${(@)_aims_stack_id[1,-2]}")
    _aims_stack_name=("${(@)_aims_stack_name[1,-2]}")
    _aims_stack_tool=("${(@)_aims_stack_tool[1,-2]}")
    _aims_stack_cwd=("${(@)_aims_stack_cwd[1,-2]}")
    _aims_stack_pending=("${(@)_aims_stack_pending[1,-2]}")
}

# bring makes the current shell "about" a c2 agent: it fetches the agent context from the server as
# inert key<TAB>value data, exports it, updates the prompt and binds the `aimsi` task root. Nesting
# a second bring stacks the current context; `leave` pops back to it.
bring() {
    emulate -L zsh
    local id="$1"

    if [[ -z "$id" ]]; then
        if [[ -n "$AIMS_AGENT_ID" ]]; then
            print -r -- "[*] current agent: ${AIMS_AGENT_NAME:-$AIMS_AGENT_ID} (depth ${AIMS_CONTEXT_DEPTH:-1}, alias: aimsi)"
        else
            print -r -- "[*] no agent context — usage: bring <agent-id>"
        fi
        return 0
    fi

    local payload
    payload="$(command aims bring "$id")" || return 1

    # Parse key<TAB>value lines as pure data — no eval, so hostile agent strings cannot execute.
    local k v
    local -A ctx
    while IFS=$'\t' read -r k v; do
        [[ -n "$k" ]] && ctx[$k]="$v"
    done <<< "$payload"

    if [[ -z "${ctx[{{.ID}}]}" ]]; then
        print -r -- "[!] bring: empty agent context for '$id'" >&2
        return 1
    fi

    # First bring in this shell: remember the base prompt. Otherwise stack the current context.
    if [[ -n "$AIMS_AGENT_ID" ]]; then
        _aims_push
    else
        _aims_saved_prompt="$PROMPT"
    fi

    export AIMS_AGENT_ID="${ctx[{{.ID}}]}"
    export AIMS_AGENT_NAME="${ctx[{{.Name}}]}"
    export AIMS_AGENT_TOOL="${ctx[{{.Tool}}]}"
    export AIMS_AGENT_CWD="${ctx[{{.CWD}}]}"
    export AIMS_AGENT_PENDING="${ctx[{{.Pending}}]}"
    export AIMS_CONTEXT_DEPTH=$(( ${#_aims_stack_id[@]} + 1 ))

    # Agent-bound task root: a function (not an alias) so it forwards arguments and can carry
    # completion later. It reads the live $AIMS_AGENT_ID, so it always targets the current agent.
    aimsi() { command aims c2 task "$AIMS_AGENT_ID" "$@" }

    _aims_apply_prompt
    print -r -- "[+] brought ${AIMS_AGENT_NAME:-$AIMS_AGENT_ID} (depth $AIMS_CONTEXT_DEPTH, alias: aimsi)"
}

# leave pops one context; at the bottom of the stack it fully restores the pre-bring shell.
leave() {
    emulate -L zsh
    if [[ -z "$AIMS_AGENT_ID" ]]; then
        print -r -- "[*] no agent context to leave"
        return 0
    fi

    if (( ${#_aims_stack_id[@]} > 0 )); then
        _aims_pop
        export AIMS_CONTEXT_DEPTH=$(( ${#_aims_stack_id[@]} + 1 ))
        _aims_apply_prompt
        print -r -- "[-] returned to ${AIMS_AGENT_NAME:-$AIMS_AGENT_ID} (depth $AIMS_CONTEXT_DEPTH)"
        return 0
    fi

    PROMPT="$_aims_saved_prompt"
    unset _aims_saved_prompt
    unset AIMS_AGENT_ID AIMS_AGENT_NAME AIMS_AGENT_TOOL AIMS_AGENT_CWD AIMS_AGENT_PENDING AIMS_CONTEXT_DEPTH
    unset _aims_stack_id _aims_stack_name _aims_stack_tool _aims_stack_cwd _aims_stack_pending
    unfunction aimsi 2>/dev/null
    print -r -- "[-] left agent context"
}
